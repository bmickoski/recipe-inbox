generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecipeStatus {
  WANT_TO_TRY
  COOKED
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  createdAt    DateTime @default(now())
  passwordHash String?
  boards       Board[]
  recipes      Recipe[]
  memberships  Member[]
  sentInvites  BoardInvite[] @relation("BoardInviteSender")
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions PushSubscription[]
}

model Board {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id])
  recipes   Recipe[]
  members   Member[]
  invites   BoardInvite[]
}

model Member {
  id          String   @id @default(uuid())
  boardId     String
  userId      String
  displayName String
  createdAt   DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model BoardInvite {
  id           String       @id @default(uuid())
  boardId      String
  invitedEmail String
  invitedBy    String
  token        String       @unique
  status       InviteStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  acceptedAt   DateTime?

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  sender User  @relation("BoardInviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([boardId, status])
}

model Recipe {
  id          String   @id @default(uuid())
  url         String
  title       String?
  image       String?
  description String?
  status      RecipeStatus @default(WANT_TO_TRY)
  cookedAt    DateTime?
  notes       String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  createdBy   String
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id])
  user        User     @relation(fields: [createdBy], references: [id])

  @@index([boardId])
  @@index([createdBy])
  @@index([boardId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
